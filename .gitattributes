# Auto detect text files and perform LF normalization
* text=auto

# Source code
*.py text diff=python
*.js text diff=javascript
*.jsx text diff=javascript
*.ts text diff=typescript
*.tsx text diff=typescript
*.json text
*.yaml text
*.yml text
*.md text
*.txt text
*.sql text

# Shell scripts
*.sh text eol=lf

# Windows
*.bat text eol=crlf

# Images
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.svg text

# Fonts
*.ttf binary
*.woff binary
*.woff2 binary

# Archives
*.zip binary
*.tar binary
*.gz binary

# Lock files (should be treated as text for some package managers)
package-lock.json text
yarn.lock text
pnpm-lock.yaml text
